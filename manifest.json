{
  "manifest_version": 3,
  "version": "3.0.0",
  "name": "Tabs",
  "description": "Save and manage links in a lightweight side panel with themes, fonts, and shortcuts.",
  "action": {
    "default_icon": "dist/assets/img/icon.png"
  },
  "permissions": ["storage", "sidePanel", "tabs", "activeTab", "notifications"],
  "host_permissions": ["file:///*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "dist/index.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    },
    "save_current": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Save current tab to Tabs"
    }
  },
  "icons": {
    "16": "dist/assets/img/icon.png",
    "32": "dist/assets/img/icon.png",
    "48": "dist/assets/img/icon.png",
    "128": "dist/assets/img/icon.png"
  }
}

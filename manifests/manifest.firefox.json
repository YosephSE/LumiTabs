{
  "manifest_version": 3,
  "version": "3.0.0",
  "name": "Tabs",
  "description": "Save and manage links in a lightweight side panel with themes, fonts, and shortcuts.",
  "action": {
    "default_icon": "assets/img/icon.png"
  },
  "permissions": ["storage", "tabs", "activeTab", "notifications"],
  "host_permissions": ["file:///*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "sidebar_action": {
    "default_panel": "index.html",
    "default_icon": "assets/img/icon.png",
    "default_title": "Tabs"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    },
    "save_current": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Save current tab to Tabs"
    }
  },
  "icons": {
    "16": "assets/img/icon.png",
    "32": "assets/img/icon.png",
    "48": "assets/img/icon.png",
    "128": "assets/img/icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabs@app.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}